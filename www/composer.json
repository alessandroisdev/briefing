{
    "name": "alessandroisdev/briefing",
    "description": "Sistema Simplificado de Briefing MVC",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "bramus/router": "~1.6",
        "illuminate/database": "^11.0",
        "illuminate/events": "^11.0",
        "robmorgan/phinx": "^0.16.2",
        "predis/predis": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "eftec/bladeone": "^4.9",
        "phpmailer/phpmailer": "^7.0",
        "symfony/console": "^8.0",
        "illuminate/http": "^11.0",
        "dompdf/dompdf": "^3.1",
        "monolog/monolog": "^3.10",
        "filp/whoops": "^2.18"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Core/Helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    }
}
